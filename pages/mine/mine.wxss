page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #f8f3e8;
  color: #3d3529;
}

.page-scroll {
  flex: 1;
  width: 100%;
  height: 0;
  min-height: 0;
}

.mine-container {
  position: relative;
  overflow: hidden;
}

.paper-bg {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: .14;
  pointer-events: none;
}

.mine-content {
  position: relative;
  z-index: 1;
  padding: 30rpx 28rpx calc(150rpx + env(safe-area-inset-bottom));
}

.profile-card,
.points-card,
.intro-card,
.collection-section,
.state-card {
  border: 1rpx solid rgba(185, 156, 107, .28);
  border-radius: 22rpx;
  background: rgba(255, 253, 247, .9);
  box-shadow: 0 8rpx 24rpx rgba(100, 75, 38, .08);
}

.profile-card {
  padding: 28rpx;
}

.header-login-hint,
.header-user,
.points-card,
.section-heading {
  display: flex;
  align-items: center;
}

.avatar-placeholder,
.user-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(185, 156, 107, .5);
  background: #f5ead5;
}

.login-copy,
.user-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-left: 20rpx;
}

.login-title,
.user-name {
  color: #594221;
  font-size: 31rpx;
  font-weight: 600;
}

.login-subtitle,
.user-id {
  margin-top: 8rpx;
  color: #9c8e76;
  font-size: 22rpx;
}

.user-avatar {
  border: 3rpx solid #e5d1aa;
  background: #eee8dc;
}

.logout-link {
  padding: 15rpx;
  color: #a08f72;
  font-size: 23rpx;
}

.points-card {
  margin-top: 22rpx;
  padding: 26rpx;
}

.points-info {
  width: 120rpx;
  display: flex;
  flex-direction: column;
}

.points-num {
  color: #9b743a;
  font-size: 44rpx;
  font-weight: 700;
}

.points-label {
  color: #9b907e;
  font-size: 21rpx;
}

.checkin-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.checkin-title {
  font-size: 27rpx;
  font-weight: 600;
}

.checkin-subtitle {
  margin-top: 6rpx;
  color: #a69a86;
  font-size: 19rpx;
}

.checkin-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.bonus-entry,
.bonus-claimed {
  font-size: 20rpx;
}

.bonus-entry {
  color: #9b743a;
  text-decoration: underline;
}

.bonus-claimed {
  color: #aaa08f;
}

.intro-card,
.collection-section {
  margin-top: 22rpx;
  padding: 26rpx;
}

.card-title {
  color: #634a24;
  font-size: 29rpx;
  font-weight: 600;
}

.intro-text {
  display: block;
  margin-top: 16rpx;
  color: #766b5a;
  font-size: 24rpx;
  line-height: 1.8;
}

.state-card {
  min-height: 260rpx;
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  color: #8d806b;
  font-size: 24rpx;
}

.retry-button,
.login-button {
  margin: 4rpx 0 0;
  padding: 0 34rpx;
  height: 62rpx;
  line-height: 62rpx;
  border: 1rpx solid #b99c6b;
  border-radius: 32rpx;
  background: #fffaf0;
  color: #795a2c;
  font-size: 24rpx;
}

.retry-button::after,
.login-button::after {
  border: none;
}

.section-heading {
  justify-content: space-between;
}

.collection-count {
  color: #a79982;
  font-size: 22rpx;
}

.empty-tip {
  min-height: 230rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: #9b907e;
  font-size: 23rpx;
}

.collection-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 22rpx;
}

.collection-item {
  overflow: hidden;
  border-radius: 16rpx;
  background: #fff;
}

.collection-img {
  width: 100%;
  height: 300rpx;
  display: block;
  background: #eee8dc;
}

.collection-title {
  display: block;
  padding: 15rpx;
  overflow: hidden;
  color: #625746;
  font-size: 24rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}
