page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #f8f3e8;
  color: #3d3529;
}

.page-scroll {
  flex: 1;
  width: 100%;
  height: 0;
  min-height: 0;
}

.page-shell {
  position: relative;
  overflow: hidden;
}

.paper-bg {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: .16;
  pointer-events: none;
}

.content {
  position: relative;
  z-index: 1;
  padding: 30rpx 28rpx calc(150rpx + env(safe-area-inset-bottom));
}

.top-row,
.date-heading,
.city-picker,
.account-entry,
.action-row,
.weather-title,
.weather-body,
.section-heading {
  display: flex;
  align-items: center;
}

.top-row {
  justify-content: space-between;
}

.date-heading {
  gap: 18rpx;
}

.date-text {
  color: #765528;
  font-size: 44rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.week-text {
  color: #9d8b70;
  font-size: 24rpx;
}

.city-picker {
  width: fit-content;
  gap: 6rpx;
  margin-top: 12rpx;
  color: #5d5548;
  font-size: 26rpx;
}

.change-city {
  margin-left: 8rpx;
  color: #a98b5d;
  font-size: 22rpx;
}

.account-entry {
  flex-direction: column;
  gap: 4rpx;
  color: #8e6d3a;
  font-size: 22rpx;
}

.color-panel {
  margin-top: 28rpx;
  padding: 24rpx 26rpx;
  border: 1rpx solid rgba(183, 146, 87, .38);
  border-radius: 22rpx;
  background: rgba(255, 253, 247, .86);
  box-shadow: 0 10rpx 28rpx rgba(118, 85, 40, .08);
}

.color-row {
  display: flex;
  align-items: flex-start;
  min-height: 54rpx;
}

.color-row + .color-row {
  margin-top: 12rpx;
}

.color-label {
  width: 130rpx;
  padding-top: 6rpx;
  font-size: 25rpx;
  font-weight: 600;
}

.color-label.best {
  color: #9b743a;
}

.color-label.second {
  color: #82705a;
}

.color-label.avoid {
  color: #9c6658;
}

.color-tags {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.color-tag {
  padding: 7rpx 20rpx;
  border-radius: 24rpx;
  background: #f3ead8;
  color: #625541;
  font-size: 23rpx;
}

.action-row {
  gap: 20rpx;
  margin-top: 22rpx;
}

.outline-button {
  flex: 1;
  height: 68rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border: 1rpx solid #b99c6b;
  border-radius: 36rpx;
  background: rgba(255, 253, 247, .78);
  color: #785c30;
  font-size: 25rpx;
}

.share-button {
  margin: 0;
  padding: 0;
  line-height: normal;
}

.share-button::after {
  border: none;
}

.date-strip {
  width: 100%;
  margin-top: 24rpx;
}

.date-strip-inner {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  gap: 8rpx;
  padding: 4rpx;
}

.date-item {
  flex: 1;
  width: 0;
  min-width: 0;
  height: 92rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(183, 146, 87, .35);
  border-radius: 18rpx;
  background: rgba(255, 253, 247, .82);
  color: #766a59;
}

.date-item.is-active {
  border-color: #a77d3f;
  color: #76501f;
  background: linear-gradient(180deg, #fffdf7, #ead8b5);
  box-shadow: 0 6rpx 14rpx rgba(126, 91, 37, .14);
}

.date-item.is-locked {
  opacity: .68;
}

.date-label {
  font-size: 20rpx;
}

.date-day {
  margin-top: 4rpx;
  font-size: 29rpx;
  font-weight: 600;
}

.weather-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 253, 247, .9);
  box-shadow: 0 8rpx 24rpx rgba(100, 78, 47, .08);
}

.weather-title {
  gap: 8rpx;
  font-size: 27rpx;
  font-weight: 600;
}

.weather-status {
  margin-left: auto;
  color: #a29176;
  font-size: 22rpx;
  font-weight: 400;
}

.weather-body {
  margin-top: 16rpx;
}

.weather-icon {
  font-size: 42rpx;
}

.weather-temp {
  width: 70rpx;
  margin-left: 14rpx;
  color: #85642f;
  font-size: 34rpx;
}

.weather-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 5rpx;
  color: #726957;
  font-size: 21rpx;
  line-height: 1.5;
}

.advice-block {
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #eee5d5;
}

.advice-title {
  display: flex;
  align-items: center;
  gap: 9rpx;
  color: #795a2c;
  font-size: 27rpx;
  font-weight: 600;
}

.advice-text {
  display: block;
  margin-top: 12rpx;
  color: #6f6555;
  font-size: 24rpx;
  line-height: 1.7;
}

.advice-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.advice-tags text {
  padding: 6rpx 18rpx;
  border-radius: 22rpx;
  background: #f1e8d7;
  color: #806a49;
  font-size: 21rpx;
}

.skincare-block {
  padding-bottom: 2rpx;
}
