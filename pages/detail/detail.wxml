<!--
  穿搭详情页模板（Vant版）
  布局：顶部大图 + 标签 + 描述 + 单品列表 + 底栏操作
-->
<view class="detail-container" wx:if="{{!loading && outfit}}">
  <!-- 顶部穿搭大图 -->
  <view class="detail-hero">
    <image class="hero-img" src="{{outfit.coverUrl}}" mode="aspectFill" />
    <!-- 锁定蒙层 -->
    <van-overlay show="{{isLocked}}" z-index="10">
      <view class="lock-overlay">
        <van-icon name="lock" size="60rpx" color="#fff" />
        <text class="lock-text">观看广告或使用积分解锁更多内容</text>
      </view>
    </van-overlay>
  </view>

  <!-- 穿搭信息 -->
  <view class="detail-info">
    <text class="detail-title">{{outfit.title}}</text>

    <!-- 标签 -->
    <view class="tag-list">
      <van-tag
        wx:for="{{outfit.tags}}"
        wx:key="*this"
        type="primary"
        size="medium"
        custom-style="margin-right:12rpx;margin-bottom:8rpx;"
      >
        {{item}}
      </van-tag>
    </view>

    <!-- 描述 -->
    <text class="detail-desc">{{outfit.description}}</text>
  </view>

  <!-- 单品列表 -->
  <view class="items-section" wx:if="{{!isLocked}}">
    <text class="section-title">穿搭单品</text>
    <view class="item-card" wx:for="{{outfit.items}}" wx:key="_id">
      <image class="item-img" src="{{item.imageUrl}}" mode="aspectFill" />
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <text class="item-brand">{{item.brand}}</text>
      </view>
      <van-icon name="arrow" size="28rpx" color="#ccc" />
    </view>
  </view>
</view>

<!-- 底部操作栏 -->
<view class="bottom-bar" wx:if="{{!loading && outfit}}">
  <!-- 锁定状态：展示解锁按钮 -->
  <block wx:if="{{isLocked}}">
    <van-button
      round
      block
      color="#667eea"
      custom-style="height:80rpx;font-size:28rpx;"
      bind:click="onWatchAd"
    >
      看广告解锁
    </van-button>
    <van-button
      round
      block
      plain
      type="primary"
      custom-style="height:80rpx;font-size:28rpx;margin-left:20rpx;"
      bind:click="onUnlockByPoints"
    >
      积分解锁
    </van-button>
  </block>

  <!-- 非锁定状态 -->
  <block wx:else>
    <van-button
      round
      block
      icon="{{isCollected ? 'like' : 'like-o'}}"
      type="{{isCollected ? 'danger' : 'default'}}"
      custom-style="height:80rpx;font-size:28rpx;"
      bind:click="onToggleCollect"
    >
      {{isCollected ? '已收藏' : '收藏'}}
    </van-button>
  </block>
</view>

<!-- 加载中 -->
<view class="loading-container" wx:if="{{loading}}">
  <van-loading size="48rpx" color="#667eea" vertical>加载中...</van-loading>
</view>
