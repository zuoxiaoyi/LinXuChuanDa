<navigation-bar
  title="穿搭详情"
  back="{{true}}"
  color="#3d3529"
  background="#fffdf7"
></navigation-bar>

<scroll-view
  class="page-scroll"
  scroll-y
  enhanced
  bounces="{{false}}"
  show-scrollbar="{{false}}"
  enable-back-to-top
>
<view class="detail-page">
  <image class="paper-bg" src="/images/common/bg.jpg" mode="aspectFill" />

  <view class="detail-content">
    <view class="date-heading">
      <text>{{dateText}}</text>
      <text class="date-subtitle">今日场景穿搭</text>
    </view>

    <view class="state-container" wx:if="{{loading}}">
      <van-loading size="46rpx" color="#b08a4d" vertical>加载穿搭方案...</van-loading>
    </view>

    <view class="state-container" wx:elif="{{error}}">
      <van-icon name="warning-o" size="58rpx" color="#b08a4d" />
      <text>{{error}}</text>
      <button class="retry-button" bindtap="onRetry">重新加载</button>
    </view>

    <view class="state-container" wx:elif="{{bestList.length === 0 && secondList.length === 0}}">
      <van-icon name="photo-o" size="60rpx" color="#c8b999" />
      <text>当天还没有配置穿搭方案</text>
    </view>

    <block wx:else>
      <view class="recommend-group">
        <view class="group-title">
          <text class="rank-name">最佳</text>
          <text class="rank-description">优先推荐的场景搭配</text>
        </view>
        <view class="outfit-grid">
          <view class="outfit-card" wx:for="{{bestList}}" wx:key="_id">
            <image
              class="outfit-image"
              wx:if="{{item.coverUrl}}"
              src="{{item.coverUrl}}"
              mode="aspectFill"
              lazy-load
            />
            <view class="image-placeholder" wx:else>
              <van-icon name="photo-o" size="48rpx" color="#c9bfae" />
            </view>
            <text class="scene-name">{{item.sceneName}}</text>
            <text class="outfit-title">{{item.title}}</text>
            <view
              class="collect-button {{item.isCollected ? 'is-collected' : ''}}"
              data-id="{{item._id}}"
              catchtap="onToggleCollect"
            >
              <van-icon name="{{item.isCollected ? 'star' : 'star-o'}}" size="30rpx" />
            </view>
          </view>
        </view>
      </view>

      <view class="recommend-group second-group">
        <view class="group-title">
          <text class="rank-name">次佳</text>
          <text class="rank-description">同样适合的备选搭配</text>
        </view>
        <view class="outfit-grid">
          <view class="outfit-card" wx:for="{{secondList}}" wx:key="_id">
            <image
              class="outfit-image"
              wx:if="{{item.coverUrl}}"
              src="{{item.coverUrl}}"
              mode="aspectFill"
              lazy-load
            />
            <view class="image-placeholder" wx:else>
              <van-icon name="photo-o" size="48rpx" color="#c9bfae" />
            </view>
            <text class="scene-name">{{item.sceneName}}</text>
            <text class="outfit-title">{{item.title}}</text>
            <view
              class="collect-button {{item.isCollected ? 'is-collected' : ''}}"
              data-id="{{item._id}}"
              catchtap="onToggleCollect"
            >
              <van-icon name="{{item.isCollected ? 'star' : 'star-o'}}" size="30rpx" />
            </view>
          </view>
        </view>
      </view>

      <view class="accessory-section">
        <text class="accessory-heading">幸运配饰</text>
        <view class="accessory-list">
          <view class="accessory-item" wx:for="{{accessories}}" wx:key="id">
            <text class="accessory-symbol">{{item.symbol}}</text>
            <text class="accessory-name">{{item.name}}</text>
            <text class="accessory-description">{{item.description}}</text>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>
</scroll-view>

<bottom-nav current=""></bottom-nav>
