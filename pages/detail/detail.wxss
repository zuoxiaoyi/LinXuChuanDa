page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #f8f3e8;
  color: #3d3529;
}

.page-scroll {
  flex: 1;
  width: 100%;
  height: 0;
  min-height: 0;
}

.detail-page {
  position: relative;
  overflow: hidden;
}

.paper-bg {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: .13;
  pointer-events: none;
}

.detail-content {
  position: relative;
  z-index: 1;
  padding: 28rpx 24rpx calc(150rpx + env(safe-area-inset-bottom));
}

.date-heading {
  display: flex;
  align-items: baseline;
  gap: 18rpx;
  color: #684b20;
  font-size: 33rpx;
  font-weight: 600;
}

.date-subtitle {
  color: #a3947a;
  font-size: 21rpx;
  font-weight: 400;
}

.recommend-group {
  margin-top: 26rpx;
}

.second-group {
  margin-top: 32rpx;
}

.group-title {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.rank-name {
  color: #6d5025;
  font-size: 29rpx;
  font-weight: 700;
}

.rank-description {
  color: #a1947e;
  font-size: 21rpx;
}

.outfit-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.outfit-card {
  position: relative;
  overflow: hidden;
  padding-bottom: 14rpx;
  border: 1rpx solid rgba(185, 156, 107, .28);
  border-radius: 18rpx;
  background: rgba(255, 253, 247, .94);
  box-shadow: 0 6rpx 18rpx rgba(100, 75, 38, .08);
}

.outfit-image,
.image-placeholder {
  width: 100%;
  height: 310rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eee8dc;
}

.scene-name,
.outfit-title {
  display: block;
  padding: 0 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.scene-name {
  margin-top: 12rpx;
  color: #8b6630;
  font-size: 23rpx;
  font-weight: 600;
}

.outfit-title {
  width: calc(100% - 48rpx);
  box-sizing: border-box;
  margin-top: 5rpx;
  color: #62584a;
  font-size: 19rpx;
}

.collect-button {
  position: absolute;
  right: 8rpx;
  bottom: 9rpx;
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ad9b7b;
}

.collect-button.is-collected {
  color: #c69238;
}

.accessory-section {
  margin-top: 34rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(185, 156, 107, .28);
  border-radius: 22rpx;
  background: rgba(255, 253, 247, .88);
}

.accessory-heading {
  color: #684b20;
  font-size: 28rpx;
  font-weight: 600;
}

.accessory-list {
  display: flex;
  justify-content: space-around;
  margin-top: 22rpx;
}

.accessory-item {
  width: 30%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.accessory-symbol {
  height: 74rpx;
  font-size: 54rpx;
  line-height: 74rpx;
}

.accessory-name {
  margin-top: 8rpx;
  color: #665033;
  font-size: 23rpx;
  font-weight: 600;
}

.accessory-description {
  margin-top: 5rpx;
  color: #a29683;
  font-size: 18rpx;
}

.state-container {
  min-height: 65vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  color: #8d806b;
  font-size: 25rpx;
}

.retry-button {
  margin: 6rpx 0 0;
  padding: 0 34rpx;
  height: 62rpx;
  line-height: 62rpx;
  border: 1rpx solid #b99c6b;
  border-radius: 32rpx;
  background: #fffaf0;
  color: #795a2c;
  font-size: 24rpx;
}

.retry-button::after {
  border: none;
}
