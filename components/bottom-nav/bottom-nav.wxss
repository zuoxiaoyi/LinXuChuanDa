.nav-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  height: 104rpx;
  padding-bottom: env(safe-area-inset-bottom);
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255, 253, 247, .96);
  border-top: 1rpx solid rgba(185, 156, 107, .25);
  box-shadow: 0 -8rpx 28rpx rgba(119, 91, 45, .08);
}

.nav-item {
  width: 220rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: 1rpx solid transparent;
  border-radius: 40rpx;
  color: #8c826f;
  font-size: 27rpx;
}

.nav-item.is-active {
  color: #9b743a;
  border-color: rgba(185, 156, 107, .55);
  background: linear-gradient(180deg, #fffdf7 0%, #f3e5c8 100%);
  box-shadow: inset 0 0 12rpx rgba(255, 255, 255, .9),
    0 5rpx 14rpx rgba(146, 107, 48, .14);
}
